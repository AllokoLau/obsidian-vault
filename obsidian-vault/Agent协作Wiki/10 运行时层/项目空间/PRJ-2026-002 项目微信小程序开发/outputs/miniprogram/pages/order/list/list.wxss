/** 订单列表页 */

.order-tabs {
  display: flex;
  background: #fff;
  padding: 0 16px;
  border-bottom: 1px solid #eee;
}

.otab {
  padding: 10px 0;
  font-size: 13px;
  color: #666;
  margin-right: 24px;
  border-bottom: 2px solid transparent;
}

.otab.active {
  color: #07c160;
  border-bottom-color: #07c160;
  font-weight: 500;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  margin: 10px 16px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  padding: 10px 14px;
  border-bottom: 1px solid #f5f5f5;
  font-size: 13px;
}

.order-no { color: #999; }

.order-status { font-weight: 500; }
.order-status.pending { color: #faad14; }
.order-status.completed { color: #07c160; }
.order-status.cancelled { color: #999; }

.order-products { padding: 10px 14px; }

.order-product {
  display: flex;
  align-items: center;
  margin-bottom: 6px;
}

.order-product:last-child { margin-bottom: 0; }

.op-img {
  width: 40px;
  height: 40px;
  background: #e8e8ed;
  border-radius: 4px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

.op-img image { width: 100%; height: 100%; border-radius: 4px; }

.op-info { flex: 1; margin-left: 8px; }
.op-name { font-size: 13px; color: #333; display: block; }
.op-spec { font-size: 12px; color: #999; display: block; }
.op-price { font-size: 13px; color: #ff4d4f; display: block; margin-top: 1px; }
.op-qty { font-size: 12px; color: #999; }

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 14px 10px;
  border-top: 1px solid #f5f5f5;
}

.order-total { font-size: 13px; color: #333; }

.order-actions { display: flex; gap: 8px; }

.action-btn {
  padding: 4px 14px;
  border-radius: 14px;
  font-size: 12px;
  border: 1px solid #ddd;
  background: #fff;
}

.action-btn.primary {
  border-color: #07c160;
  color: #07c160;
}
