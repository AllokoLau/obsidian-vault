/** 结算页 */

.page { padding-bottom: 70px; }

.section {
  background: #fff;
  margin-bottom: 10px;
  padding: 14px 16px;
}

.section-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

/* 地址区域 */
.address-section {
  display: flex;
  align-items: center;
}

.addr-icon { font-size: 24px; margin-right: 12px; }
.addr-info { flex: 1; }
.addr-name { font-size: 15px; font-weight: 600; display: block; }
.addr-detail { font-size: 13px; color: #999; margin-top: 2px; display: block; }
.arrow { color: #ccc; font-size: 16px; }

/* 商品清单 */
.checkout-item {
  display: flex;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f5f5f5;
}

.checkout-item:last-child { border-bottom: none; }

.ci-img {
  width: 48px;
  height: 48px;
  background: #e8e8ed;
  border-radius: 6px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.ci-img image { width: 100%; height: 100%; border-radius: 6px; }

.ci-info { flex: 1; margin-left: 10px; }
.ci-name { font-size: 13px; color: #333; display: block; }
.ci-spec { font-size: 12px; color: #999; display: block; }
.ci-price { font-size: 14px; font-weight: 600; color: #ff4d4f; display: block; margin-top: 2px; }
.ci-qty { font-size: 13px; color: #999; }

/* 费用汇总 */
.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  color: #333;
  padding: 4px 0;
}

.summary-row.total {
  font-size: 16px;
  font-weight: 600;
  border-top: 1px solid #eee;
  padding-top: 8px;
  margin-top: 4px;
}

.summary-row.total .amount { color: #ff4d4f; }

/* 备注 */
.remark-input {
  width: 100%;
  font-size: 14px;
  color: #333;
  border: none;
  padding: 8px 0;
  background: #f9f9f9;
  border-radius: 8px;
  padding: 8px 12px;
}

/* 底部结算 */
.checkout-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  background: #fff;
  border-top: 1px solid #eee;
}

.footer-amount { font-size: 14px; }
.footer-amount .price { font-size: 20px; }

.btn-pay {
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 22px;
  padding: 12px 32px;
  font-size: 15px;
  font-weight: 600;
}
