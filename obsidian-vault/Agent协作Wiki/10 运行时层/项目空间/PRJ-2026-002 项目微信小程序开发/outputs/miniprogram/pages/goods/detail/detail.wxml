<view class="page">
  <!-- 商品图片 -->
  <view class="detail-img">
    <image wx:if="{{goods.image}}" src="{{goods.image}}" mode="widthFix" />
    <text wx:else class="img-placeholder">📷 商品图</text>
  </view>

  <!-- 商品信息 -->
  <view class="detail-body">
    <text class="detail-name">{{goods.name}}</text>
    <view class="detail-price">
      <text class="price">¥{{goods.price}}</text>
      <text wx:if="{{goods.originalPrice}}" class="original-price">¥{{goods.originalPrice}}</text>
    </view>

    <!-- 规格选择 -->
    <view wx:if="{{specs.length}}" class="spec-section">
      <text class="section-title">规格</text>
      <view class="spec-list">
        <view wx:for="{{specs}}" wx:key="index"
              class="spec-item {{currentSpec === index ? 'active' : ''}}"
              bindtap="onSelectSpec" data-index="{{index}}">
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 库存信息 -->
    <view class="detail-stock">
      <text>已售 {{goods.soldCount || 0}} 份</text>
      <text class="dot">·</text>
      <text>{{goods.stock > 0 ? '库存充足' : '暂时缺货'}}</text>
    </view>

    <!-- 商品描述 -->
    <view class="detail-desc">
      <text class="section-title">商品描述</text>
      <text class="desc-text">{{goods.description || '暂无描述'}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="detail-footer">
    <view class="footer-info">
      <text class="label">已选</text>
      <text class="count">{{cartCount || 0}}</text>
      <text class="label">件</text>
      <text class="divider">|</text>
      <text class="price">¥{{totalPrice}}</text>
    </view>
    <button class="btn-cart" bindtap="onAddToCart">加入购物车</button>
  </view>
</view>
