/** 首页 - 商品列表 */

.page {
  padding-bottom: 20px;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: #fff;
}

.search-input {
  flex: 1;
  background: #f5f5f7;
  border-radius: 20px;
  padding: 8px 14px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.search-icon { font-size: 14px; }
.search-text { font-size: 13px; color: #999; }

.filter-btn {
  color: #07c160;
  font-size: 14px;
  font-weight: 500;
  margin-left: 10px;
}

/* 分类标签 */
.category-bar {
  display: flex;
  padding: 8px 16px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
  white-space: nowrap;
}

.cat-item {
  display: inline-block;
  padding: 6px 16px;
  font-size: 13px;
  color: #666;
  border-bottom: 2px solid transparent;
}

.cat-item.active {
  color: #07c160;
  border-bottom-color: #07c160;
  font-weight: 600;
}

/* 商品网格 */
.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding: 12px 16px;
}
