/** "我的"页 */

/* 用户信息 */
.user-profile {
  display: flex;
  align-items: center;
  padding: 24px 16px;
  background: #fff;
  margin-bottom: 10px;
}

.avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 12px;
  background: #f0f0f0;
}

.avatar image { width: 100%; height: 100%; }

.avatar-placeholder {
  display: block;
  width: 56px;
  height: 56px;
  line-height: 56px;
  text-align: center;
  font-size: 28px;
}

.user-meta { flex: 1; }
.nickname { font-size: 18px; font-weight: 600; color: #1a1a1a; display: block; }
.user-desc { font-size: 13px; color: #999; margin-top: 2px; display: block; }

/* 订单统计 */
.order-summary {
  display: flex;
  background: #fff;
  padding: 16px 0;
  margin-bottom: 10px;
}

.os-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.os-num { font-size: 22px; font-weight: 700; color: #333; }
.os-label { font-size: 12px; color: #999; }

/* 功能列表 */
.menu-list {
  background: #fff;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #f5f5f5;
}

.menu-icon { font-size: 20px; margin-right: 12px; }
.menu-label { flex: 1; font-size: 14px; color: #333; }
.menu-desc { font-size: 12px; color: #999; margin-right: 8px; }
.arrow { color: #ccc; font-size: 14px; }

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 30px 0;
  font-size: 12px;
  color: #ccc;
}
