/** 购物车页 */

.page { padding-bottom: 70px; }

.cart-list { padding: 0; }

.cart-item {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background: #fff;
  border-bottom: 1px solid #f5f5f5;
}

.cart-checkbox {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid #ddd;
  margin-right: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cart-checkbox.checked {
  background: #07c160;
  border-color: #07c160;
  color: #fff;
  font-size: 12px;
}

.cart-img {
  width: 60px;
  height: 60px;
  background: #e8e8ed;
  border-radius: 8px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.cart-img image { width: 100%; height: 100%; border-radius: 8px; }

.cart-info {
  flex: 1;
  margin-left: 10px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.cart-name { font-size: 14px; font-weight: 500; color: #333; }
.cart-spec { font-size: 12px; color: #999; }
.cart-price { font-size: 15px; color: #ff4d4f; font-weight: 600; margin-top: 2px; }

.cart-qty {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
}

.qty-btn {
  width: 24px;
  height: 24px;
  line-height: 24px;
  text-align: center;
  border-radius: 50%;
  border: 1px solid #ddd;
  background: #fff;
  font-size: 14px;
  padding: 0;
}

.qty-num { font-size: 14px; min-width: 20px; text-align: center; }

/* 底部结算栏 */
.cart-footer {
  position: fixed;
  bottom: 50px;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  background: #fff;
  border-top: 1px solid #eee;
}

.footer-left {
  display: flex;
  align-items: center;
}

.select-all { font-size: 14px; color: #333; }

.footer-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.footer-total { display: flex; align-items: baseline; gap: 4px; }
.total-label { font-size: 14px; color: #333; }

.btn-checkout {
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 20px;
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 600;
}

.btn-checkout[disabled] {
  background: #ccc;
}
