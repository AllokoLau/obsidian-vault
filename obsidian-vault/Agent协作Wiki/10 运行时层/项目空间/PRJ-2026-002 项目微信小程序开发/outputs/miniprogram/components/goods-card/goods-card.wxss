/** 商品卡片组件 */

.goods-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.goods-img {
  height: 140px;
  background: #e8e8ed;
  display: flex;
  align-items: center;
  justify-content: center;
}

.goods-img image {
  width: 100%;
  height: 100%;
}

.img-placeholder { font-size: 24px; color: #999; }

.goods-info {
  padding: 8px 10px 12px;
}

.goods-name {
  font-size: 13px;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-tags { margin-top: 4px; }

.tag {
  display: inline-block;
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 4px;
}

.hot-tag { background: #fff0f0; color: #ff4d4f; }
.new-tag { background: #f0fff0; color: #07c160; }

.goods-price {
  font-size: 16px;
  color: #ff4d4f;
  font-weight: 700;
  margin-top: 4px;
}
